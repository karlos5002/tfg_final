# ==============================================================================
# Cooperativa San Juan Bautista — .htaccess para Hostinger Premium
# ==============================================================================
# Reglas de servidor Apache. En XAMPP local también funcionan, pero algunas
# (HTTPS, www) están envueltas en SetEnv para no entorpecer el desarrollo.
# ==============================================================================

# ── Charset por defecto ───────────────────────────────────────────────────
AddDefaultCharset UTF-8

# ── Documentos por defecto ────────────────────────────────────────────────
DirectoryIndex index.php index.html

# ── No mostrar el listado del directorio si falta el index ────────────────
Options -Indexes

# ── Páginas de error personalizadas (opcional, deja comentado si no las creas) ──
# ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php


# ── Forzar HTTPS en producción (Hostinger ya entrega cert SSL gratuito) ───
# La condición evita la regla en local (XAMPP no tiene SSL configurado).
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) HTTPS: si NO estamos en https Y NO estamos en localhost → redirigir.
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\. [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2) Quitar "www." (o añadir www., escoge una). Aquí: SIN www.
    #    Comenta este bloque si prefieres con www. en tu dominio canónico.
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>


# ── Bloquear acceso a carpetas y archivos internos ────────────────────────
# config/ vendor/ database/ scratch/ logs/ NUNCA deben servirse al cliente.
RedirectMatch 403 ^/+config(/|$)
RedirectMatch 403 ^/+vendor(/|$)
RedirectMatch 403 ^/+database(/|$)
RedirectMatch 403 ^/+scratch(/|$)
RedirectMatch 403 ^/+logs(/|$)
RedirectMatch 403 ^/+\.git(/|$)
RedirectMatch 403 ^/+\.env
RedirectMatch 403 ^/+composer\.(json|lock)$


# ── Caché agresiva para estáticos (rendimiento PWA) ───────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg            "access plus 1 year"
    ExpiresByType image/jpeg           "access plus 1 year"
    ExpiresByType image/gif            "access plus 1 year"
    ExpiresByType image/png            "access plus 1 year"
    ExpiresByType image/webp           "access plus 1 year"
    ExpiresByType image/svg+xml        "access plus 1 year"
    ExpiresByType image/x-icon         "access plus 1 year"
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript      "access plus 1 month"
    ExpiresByType font/woff            "access plus 1 year"
    ExpiresByType font/woff2           "access plus 1 year"
    # No cachear el manifest ni el SW: deben actualizarse rápido
    ExpiresByType application/manifest+json "access plus 0 seconds"
    ExpiresByType text/cache-manifest  "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Service Worker: nunca cachear (ya lo hace el navegador correctamente)
    <FilesMatch "sw\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    # Cabeceras de seguridad básicas
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>


# ── Compresión gzip ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
